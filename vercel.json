{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["syd1"],
  "functions": {
    "api/cron/dispatch.js": {
      "maxDuration": 300
    },
    "api/webhook/elevenlabs-call-complete.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/dispatch",
      "schedule": "*/15 23 * * 1-5"
    },
    {
      "path": "/api/cron/dispatch",
      "schedule": "*/15 0-5 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "0" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/(.*)\\.(woff|woff2|ttf|css|js|svg|png|jpg|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/sydney-coffee-price-report-2026",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sydney-coffee-price-report-2026", "destination": "/sydney-coffee-price-report-2026.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "redirects": [
    { "source": "/v2", "destination": "/", "permanent": true },
    { "source": "/v3", "destination": "/", "permanent": true },
    { "source": "/v4", "destination": "/", "permanent": true },
    { "source": "/v5", "destination": "/sydney-coffee-price-report-2026", "permanent": true }
  ]
}
