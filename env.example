# Call provider — "elevenlabs" or "twilio" or "bland"
CALL_PROVIDER=elevenlabs

# ElevenLabs — Conversational AI (if CALL_PROVIDER=elevenlabs)
# Get from elevenlabs.io/app → API Keys
# Create agent at elevenlabs.io/agents, add phone number in dashboard
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# Bland.ai — Voice calling API (if CALL_PROVIDER=bland)
# Get your key at https://app.bland.ai
BLAND_AI_API_KEY=

# Twilio + OpenAI — Voice calling (if CALL_PROVIDER=twilio)
# Get from twilio.com/console and platform.openai.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OPENAI_API_KEY=

# Google Places API — Cafe discovery
# Enable Places API at https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# Supabase — Database
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Webhook — Must be publicly accessible
WEBHOOK_BASE_URL=https://flatwhiteindex.com.au

# Webhook authentication — shared secret for verifying webhook origin
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Admin panel — secret key for /admin login + bootstrap
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# WebAuthn — Passkey auth (optional, auto-derived from WEBHOOK_BASE_URL)
# WEBAUTHN_RP_ID=flatwhiteindex.com.au
# WEBAUTHN_ORIGIN=https://flatwhiteindex.com.au

# Email — Resend (resend.com)
# Welcome emails sent automatically on signup, weekly digest via cron
RESEND_API_KEY=
EMAIL_FROM=Flat White Index <hello@flatwhiteindex.com.au>

# Server port
PORT=3001
